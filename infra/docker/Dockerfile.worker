FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

COPY pyproject.toml .
RUN uv sync --no-dev --extra worker --frozen 2>/dev/null || uv sync --no-dev --extra worker

COPY worker/ worker/

CMD ["uv", "run", "python", "-m", "worker.runner"]
